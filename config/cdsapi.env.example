# Copernicus Climate Data Store (CDS) API Configuration
# Copy this file to cdsapi.env and add your credentials
# DO NOT commit the actual cdsapi.env file with your real credentials

# Option 1: Environment variable format
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=your_cds_api_key_here

# Option 2: cdsapirc format (for ~/.cdsapirc)
# url: https://cds.climate.copernicus.eu/api
# key: your_cds_api_key_here
